# ===========================================================================
# SkyShield AI - repository ignore rules
# Keeps the repo to source only: contract, tests, tooling, and frontend code.
# ===========================================================================

# ---- Environment & secrets (never commit) ----
.env
.env.*
!.env.example
!*.env.local.example
*.pem
*.key
secrets.*

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ---- Virtual environments ----
.venv/
venv/
env/
.python-version

# ---- GenLayer / gltest run artifacts & caches ----
artifacts/
.gltest_cache/
.genvm/
*.log

# ---- Node / Next.js (frontend) ----
node_modules/
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# ---- Editor / OS cruft ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
