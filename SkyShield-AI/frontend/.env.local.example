# Copy this file to `.env.local` and fill in your values.

# Deployed SkyShield AI contract address (0x-prefixed). Optional: when unset, the
# dashboard runs in live simulation mode so every widget is fully interactive.
NEXT_PUBLIC_SKYSHIELD_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Target GenLayer network. One of: studionet | localnet | testnetAsimov | testnetBradbury
NEXT_PUBLIC_GENLAYER_CHAIN=studionet
